PORT=10000
NODE_ENV=production

# Required on Render
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pm_backend
# Alternative key supported by backend:
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/pm_backend
JWT_SECRET=replace_with_a_strong_secret

# Optional (if set, admin user is seeded automatically on startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password

# Optional
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
UPLOAD_MAX_BYTES=20971520
TELEBIRR_WEBHOOK_SECRET=

# Cloudinary (required for file uploads: manager proofs, properties, complaints, lease docs, payment receipts)
# Easiest: copy "CLOUDINARY_URL=..." from the Cloudinary dashboard → API Keys → Environment variable.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set the three values instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
